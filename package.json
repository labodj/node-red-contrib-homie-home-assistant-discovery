{
  "name": "node-red-contrib-homie-home-assistant-discovery",
  "version": "1.0.1",
  "description": "Node-RED node that converts Homie MQTT devices into Home Assistant MQTT discovery.",
  "main": "dist/homie-ha-discovery.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "sync:version": "node scripts/sync-version.mjs --write",
    "sync:version:check": "node scripts/sync-version.mjs --check",
    "copy-assets": "copyfiles -u 1 src/**/*.html dist/",
    "build": "npm run sync:version:check && npm run clean && tsc -p tsconfig.prod.json && npm run copy-assets",
    "typecheck": "npm run sync:version:check && tsc -p tsconfig.typecheck.json",
    "lint": "npm run sync:version:check && eslint src --max-warnings=0 --cache --cache-location ./.cache/eslint",
    "lint:md": "node scripts/lint-markdown.mjs",
    "format": "prettier --write \"src/**/*.{ts,html}\" \"scripts/**/*.mjs\" \"examples/**/*.json\" \"docs/**/*.md\" README.md CITATION.cff package.json jest.config.js eslint.config.mjs knip.json tsconfig*.json .prettierrc.json \".github/**/*.{yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html}\" \"scripts/**/*.mjs\" \"examples/**/*.json\" \"docs/**/*.md\" README.md CITATION.cff package.json jest.config.js eslint.config.mjs knip.json tsconfig*.json .prettierrc.json \".github/**/*.{yml,yaml}\"",
    "knip": "knip --production --strict",
    "audit:prod": "npm audit --omit=dev",
    "validate:package-doc-links": "node scripts/validate-package-doc-links.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "verify:package-contents": "node scripts/verify-package-contents.mjs",
    "check": "npm run sync:version:check && npm run typecheck && npm run lint && npm run lint:md && npm run format:check && npm run knip && npm run build && npm run validate:package-doc-links && npm run verify:package-contents && npm run verify:package && npm run test:cov && npm run audit:prod",
    "test": "npm run sync:version:check && jest --no-cache --detectOpenHandles",
    "test:cov": "npm run sync:version:check && jest --coverage --no-cache --detectOpenHandles",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run check"
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CITATION.cff"
  ],
  "keywords": [
    "node-red",
    "mqtt",
    "homie",
    "homie-iot",
    "homie-convention",
    "homie-mqtt",
    "home-assistant",
    "homeassistant",
    "home-assistant-discovery",
    "mqtt-discovery",
    "discovery",
    "smart-home",
    "home-automation",
    "iot",
    "typescript"
  ],
  "author": {
    "name": "Jacopo Labardi",
    "email": "2527836+labodj@users.noreply.github.com"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/labodj/node-red-contrib-homie-home-assistant-discovery.git"
  },
  "bugs": {
    "url": "https://github.com/labodj/node-red-contrib-homie-home-assistant-discovery/issues"
  },
  "homepage": "https://github.com/labodj/node-red-contrib-homie-home-assistant-discovery#readme",
  "node-red": {
    "nodes": {
      "homie-ha-discovery": "dist/homie-ha-discovery.js"
    },
    "version": ">=4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "homie-home-assistant-discovery": "1.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/node-red": "^1.3.5",
    "copyfiles": "^2.4.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "knip": "^6.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
